# Copy this file to .env and fill in your actual values
# Never commit .env to GitHub

# OpenRouter API key for the AI chatbot
VITE_OPENROUTER_API_KEY=your_openrouter_api_key_here

# Backend API URL
# Local dev: http://localhost:8000
# Production: https://your-render-backend-url.onrender.com
VITE_API_URL=https://your-render-backend-url.onrender.com

# ipgeolocation.io API key (Step 3 of location fallback chain)
# Get a free key at https://ipgeolocation.io
# If missing, Step 3 is skipped silently — Step 2 (ipapi.co) still runs
VITE_IPGEO_KEY=your_ipgeolocation_io_api_key

# ── Supabase (Feedback section) ───────────────────────────────────────────────
# Get these from: Supabase Dashboard → Settings → API
# ONLY use the anon/public key here — never the service role key
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
